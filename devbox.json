{
  "$schema":  "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "jq@latest",
    "shellcheck@latest",
    "libxml2@latest",
    "dpkg@latest",
    "debian-devscripts@latest",
    "rustc@latest",
    "cargo@latest",
    "clippy@latest",
    "rustfmt@latest",
    "pkg-config@latest",
    "glib@latest",
    "glib.dev",
    "blueprint-compiler@latest",
    "gtk4.dev",
    "libadwaita.dev",
    "pango.dev",
    "cairo.dev",
    "gdk-pixbuf.dev",
    "graphene.dev",
    "harfbuzz.dev",
    "vulkan-loader.dev"
  ],
  "shell": {
    "init_hook": [
      "if ! command -v dh >/dev/null; then echo 'warning: debhelper not on PATH — install with: sudo apt install debhelper lintian' >&2; fi"
    ],
    "scripts": {
      "lint": [
        "shellcheck bin/secureboot-notify sbin/secureboot-check sbin/secureboot-fix kernel/zzz-secureboot-recheck debian/postinst debian/prerm",
        "xmllint --noout polkit/com.localhost.secureboot.fix.policy",
        "devbox run ui:lint"
      ],
      "check": [
        "sudo sbin/secureboot-check | jq ."
      ],
      "build": [
        "debuild -us -uc -b -d"
      ],
      "lintian": [
        "lintian --info --display-info ../secureboot-watchdog_*.deb || true"
      ],
      "install": [
        "sudo apt install -y ../secureboot-watchdog_$(dpkg-parsechangelog -SVersion)_all.deb"
      ],
      "clean": [
        "rm -rf debian/.debhelper debian/secureboot-watchdog debian/files debian/*.substvars debian/*.log debian/debhelper-build-stamp",
        "rm -f ../secureboot-watchdog_*.deb ../secureboot-watchdog_*.buildinfo ../secureboot-watchdog_*.changes ../secureboot-watchdog_*.tar.* ../secureboot-watchdog_*.dsc",
        "(cd ui && cargo clean 2>/dev/null || true)"
      ],
      "ui:build": [
        "(cd ui && cargo build --release --locked)"
      ],
      "ui:dev": [
        "(cd ui && cargo run -- \"$@\")"
      ],
      "ui:check": [
        "(cd ui && cargo check --all-targets)"
      ],
      "ui:lint": [
        "(cd ui && cargo fmt --check)",
        "(cd ui && cargo clippy --all-targets -- -D warnings)",
        "blueprint-compiler batch-compile /tmp/blp-check ui/blueprints ui/blueprints/*.blp"
      ]
    }
  }
}
