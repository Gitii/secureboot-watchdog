#!/bin/bash
# secureboot-notify: User-session notifier for the Secure Boot watchdog.
# Reads /run/secureboot-monitor/status.json, dedupes, shows GNOME notification,
# offers a polkit-elevated fix on click.
set -uo pipefail

STATUS_FILE=${STATUS_FILE:-/run/secureboot-monitor/status.json}
STATE_FILE=${XDG_RUNTIME_DIR:-/tmp}/secureboot-notify.last
MOK_DIR=${MOK_DIR:-/var/lib/shim-signed/mok}
FIX_BIN=/usr/sbin/secureboot-fix
APP_NAME="Secure Boot"
ICON=security-high

[[ -r $STATUS_FILE ]] || exit 0
command -v jq >/dev/null || exit 0

ok=$(jq -r '.ok' "$STATUS_FILE" 2>/dev/null || echo "true")
codes=$(jq -r '.issues[].code' "$STATUS_FILE" 2>/dev/null | sort)
hash=$(printf '%s\n%s' "$ok" "$codes" | sha256sum | cut -d' ' -f1)
last=$(cat "$STATE_FILE" 2>/dev/null || true)

[[ $hash == "$last" ]] && exit 0
printf '%s\n' "$hash" > "$STATE_FILE"

[[ $ok == "true" ]] && exit 0

INFO_ONLY="SB_DISABLED LOCKDOWN_OFF MOK_PENDING TPM_PCR_DRIFT"
NEEDS_MOK_PASSWORD="MOK_NOT_ENROLLED"

# First (most severe) issue drives the headline; others summarized in body.
first_code=$(jq -r '.issues[0].code' "$STATUS_FILE")
first_summary=$(jq -r '.issues[0].summary' "$STATUS_FILE")
first_detail=$(jq -r '.issues[0].detail' "$STATUS_FILE")
issue_count=$(jq -r '.issues | length' "$STATUS_FILE")

if (( issue_count > 1 )); then
    body="$first_summary (+$((issue_count - 1)) more issues)"
else
    body="$first_summary"
fi

# Info-only path: no Fix action; just info dialog.
if grep -qw "$first_code" <<<"$INFO_ONLY"; then
    action=$(notify-send -w -u critical -a "$APP_NAME" -i "$ICON" \
        "Secure Boot needs attention" "$body" \
        -A "details=Details" -A "dismiss=Dismiss" 2>/dev/null || true)
    case $action in
        details)
            jq -r '.issues[] | "[\(.code)] \(.severity)\n\(.summary)\n\(.detail)\n"' "$STATUS_FILE" \
                | zenity --text-info --title="Secure Boot status" --width=720 --height=480 2>/dev/null || true
            ;;
    esac
    exit 0
fi

# Auto-fixable path.
action=$(notify-send -w -u critical -a "$APP_NAME" -i "$ICON" \
    "Secure Boot needs attention" "$body" \
    -A "fix=Fix now" -A "details=Details" -A "dismiss=Dismiss" 2>/dev/null || true)

case $action in
    details)
        jq -r '.issues[] | "[\(.code)] \(.severity)\n\(.summary)\n\(.detail)\n"' "$STATUS_FILE" \
            | zenity --text-info --title="Secure Boot status" --width=720 --height=480 2>/dev/null || true
        exit 0
        ;;
    fix) ;;
    *) exit 0 ;;
esac

zenity --question --width=520 \
    --title="Repair Secure Boot chain" \
    --text="<b>$first_summary</b>\n\n$first_detail\n\nRun the repair now? You will be prompted for your password." \
    --ok-label="Repair" --cancel-label="Not now" 2>/dev/null || exit 0

# Decide whether we need to prompt for a MOK enrollment password.
needs_pw=0
if grep -qw "$first_code" <<<"$NEEDS_MOK_PASSWORD"; then
    needs_pw=1
elif ! compgen -G "$MOK_DIR/*.priv" >/dev/null 2>&1; then
    # No existing MOK pair -> fix script will generate one and need a password.
    needs_pw=1
fi

password=""
if (( needs_pw )); then
    while :; do
        password=$(zenity --password --title="MOK enrollment password" 2>/dev/null) || exit 0
        confirm=$(zenity --password --title="Confirm MOK enrollment password" 2>/dev/null) || exit 0
        [[ -n $password && $password == "$confirm" ]] && break
        zenity --error --text="Passwords did not match (or were empty). Try again." 2>/dev/null || true
    done
fi

# Run the fix. Stream output to a temp log for the result dialog.
log=$(mktemp -t secureboot-fix.XXXXXX)
trap 'rm -f "$log"' EXIT

if (( needs_pw )); then
    printf '%s\n' "$password" | pkexec "$FIX_BIN" --code "$first_code" >"$log" 2>&1
    rc=$?
else
    pkexec "$FIX_BIN" --code "$first_code" </dev/null >"$log" 2>&1
    rc=$?
fi
unset password confirm

if (( rc == 0 )); then
    cat "$log" | zenity --text-info --title="Repair finished" --width=720 --height=480 2>/dev/null || true
else
    cat "$log" | zenity --text-info --title="Repair failed (exit $rc)" --width=720 --height=480 2>/dev/null || true
fi

# Force a re-evaluation on next status change.
rm -f "$STATE_FILE"
