#!/bin/bash
# secureboot-notify: User-session notifier for the Secure Boot watchdog.
# Reads /run/secureboot-monitor/status.json, dedupes, shows GNOME notification.
# On action click, hands off to the native GNOME app (secureboot-watchdog-ui).
set -uo pipefail

STATUS_FILE=${STATUS_FILE:-/run/secureboot-monitor/status.json}
STATE_FILE=${XDG_RUNTIME_DIR:-/tmp}/secureboot-notify.last
UI_BIN=${UI_BIN:-/usr/bin/secureboot-watchdog-ui}
APP_NAME="Secure Boot"
ICON=security-high

[[ -r $STATUS_FILE ]] || exit 0
command -v jq >/dev/null || exit 0

ok=$(jq -r '.ok' "$STATUS_FILE" 2>/dev/null || echo "true")
codes=$(jq -r '.issues[].code' "$STATUS_FILE" 2>/dev/null | sort)
hash=$(printf '%s\n%s' "$ok" "$codes" | sha256sum | cut -d' ' -f1)
last=$(cat "$STATE_FILE" 2>/dev/null || true)

[[ $hash == "$last" ]] && exit 0
printf '%s\n' "$hash" > "$STATE_FILE"

[[ $ok == "true" ]] && exit 0

# Pick the first issue as headline; others surface in the app.
first_code=$(jq -r '.issues[0].code' "$STATUS_FILE")
first_summary=$(jq -r '.issues[0].summary' "$STATUS_FILE")
issue_count=$(jq -r '.issues | length' "$STATUS_FILE")
if (( issue_count > 1 )); then
    body="$first_summary (+$((issue_count - 1)) more issues)"
else
    body="$first_summary"
fi

INFO_ONLY="SB_DISABLED LOCKDOWN_OFF MOK_PENDING"
if grep -qw "$first_code" <<<"$INFO_ONLY"; then
    actions=(-A "details=Details" -A "dismiss=Dismiss")
else
    actions=(-A "fix=Fix now" -A "details=Details" -A "dismiss=Dismiss")
fi

action=$(notify-send -w -u critical -a "$APP_NAME" -i "$ICON" \
    --hint=string:desktop-entry:io.github.gitii.SecurebootWatchdog \
    "Secure Boot needs attention" "$body" \
    "${actions[@]}" 2>/dev/null || true)

case $action in
    fix)
        nohup "$UI_BIN" fix --code "$first_code" >/dev/null 2>&1 &
        ;;
    details)
        nohup "$UI_BIN" details --code "$first_code" >/dev/null 2>&1 &
        ;;
esac
exit 0
