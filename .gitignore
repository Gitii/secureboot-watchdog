# debhelper build artifacts (note: keep source-tracked files like
# debian/secureboot-watchdog.lintian-overrides — that's why this list
# is specific instead of using debian/secureboot-watchdog.*)
debian/.debhelper/
debian/secureboot-watchdog/
debian/files
debian/*.substvars
debian/*.debhelper
debian/*.debhelper.log
debian/*.log
debian/debhelper-build-stamp

# dpkg-buildpackage outputs land in the parent dir; ignore if symlinked here
*.deb
*.buildinfo
*.changes
*.tar.xz
*.dsc

# devbox / nix
.devbox/

# editor noise
*.swp
*.swo
.idea/
.vscode/
.DS_Store
